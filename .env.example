# =============================================================
# Education Advisor — example environment variables
# Copy this file to `.env` and fill in your own values.
# NEVER commit `.env` to version control.
# =============================================================

# ===== EAA CLI binary source =====
# Where to download the eaa binary from when running `npm run build:eaa`.
# Default: downloads the latest release of the companion `education-advisor`
# repository (https://github.com/232252/education-advisor/releases).
EAA_RELEASE_REPO=232252/education-advisor
# Pin to a specific release tag (leave empty for "latest").
EAA_RELEASE_TAG=

# ===== Development helpers =====
# When set to "1", enables Electron remote debugging on localhost:9222.
# DO NOT enable on a machine that is reachable from an untrusted network.
ENABLE_CDP=0

# Vite dev server URL for the renderer (used by `npm run dev:electron`).
# Leave unset to use the default http://localhost:5173.
# VITE_DEV_SERVER_URL=

# ===== Telemetry =====
# The application does NOT phone home by default. Set to "1" to opt-in
# to anonymous error reports (forwarded only to your configured endpoint,
# never to the upstream maintainers).
EDUCATION_ADVISOR_TELEMETRY=0
EDUCATION_ADVISOR_TELEMETRY_ENDPOINT=


# ===== Tauri 打包签名 (GitHub Secrets, 不要填到本地 .env) =====
# 这些变量由 CI 在 .github/workflows/release-tauri.yml 里读 ${{ secrets.* }}。
# 本地 .env 留空即可, 仅作备忘。
#
# --- Tauri updater 签名 (Windows NSIS + macOS DMG 自动用) ---
# 生成: npm run signer:gen
# TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
#
# --- Apple Developer ID 应用签名 (macOS .app / .dmg) ---
# APPLE_CERTIFICATE=            # base64(p12 证书内容)
# APPLE_CERTIFICATE_PASSWORD=
# APPLE_SIGNING_IDENTITY=       # "Developer ID Application: Your Name (TEAMID)"
# APPLE_TEAM_ID=                # 10 位 team id
#
# --- Apple Notarization (避免 Gatekeeper 拦截) ---
# APPLE_ID=                     # Apple ID 邮箱
# APPLE_PASSWORD=               # app-specific password (appleid.apple.com → App Passwords)
#
# --- Windows Authenticode (可选, 需 EV 证书或 Azure Trusted Signing) ---
# 本项目默认未配, 未签名 .exe 会被 SmartScreen 拦截。
# 配置方式见 src-tauri/docs/05-BUILD-RUN.md §6。
