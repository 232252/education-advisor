---
// =============================================================
// Hero 区 — 首页第一屏
//
// 设计: 深色背景 + Rust 红发光大标题 + 一句话电梯演讲
// 动画: 用 CSS animation (translateZ 合成层, GPU 渲染, 60fps)
// 零 JS: 纯 HTML+CSS, 无水合
// =============================================================
---

<section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden bg-slab-900">
  <!-- 背景网格 (工程美学, 纯 CSS) -->
  <div
    class="absolute inset-0 opacity-10"
    style="background-image: linear-gradient(#ce412b 1px, transparent 1px), linear-gradient(90deg, #ce412b 1px, transparent 1px); background-size: 40px 40px;"
  >
  </div>

  <!-- 径向渐变光晕 (Rust 红辐射) -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(circle at 50% 40%, rgba(206, 65, 43, 0.15) 0%, transparent 60%);"
  >
  </div>

  <!-- 内容 -->
  <div class="relative z-10 text-center px-4 max-w-4xl animate-fade-in-up">
    <!-- Badge: 技术栈 -->
    <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full bg-rust/10 border border-rust/30 text-rust text-sm font-mono">
      <span>Tauri 2.0</span>
      <span class="opacity-50">·</span>
      <span>Rust 🦀</span>
      <span class="opacity-50">·</span>
      <span>React 18</span>
    </div>

    <!-- 主标题 (发光动效) -->
    <h1 class="text-5xl md:text-7xl font-black mb-6 text-white animate-glow-pulse">
      Education<br />Advisor
    </h1>

    <!-- 电梯演讲 -->
    <p class="text-xl md:text-2xl text-slate-300 mb-4 max-w-2xl mx-auto leading-relaxed">
      把班主任的日常——操行分、学生档案、多 Agent 协作、家长沟通——
      全部装进一个 <strong class="text-rust">17MB</strong> 的 Rust 桌面应用。
    </p>

    <!-- 副标题 (痛点) -->
    <p class="text-base text-slate-400 mb-10 max-w-xl mx-auto">
      18 个 AI Agent · AES-256 隐私引擎 · 12 个 LLM Provider · 三平台原生体验
    </p>

    <!-- CTA 按钮 -->
    <div class="flex flex-wrap gap-4 justify-center">
      <a
        href="/download"
        class="inline-flex items-center gap-2 px-8 py-4 bg-rust text-white rounded-lg font-bold text-lg hover:bg-rust-700 transition-all hover:scale-105 transform"
        style="will-change: transform;"
      >
        ⬇️ 立即下载
      </a>
      <a
        href="/docs/intro"
        class="inline-flex items-center gap-2 px-8 py-4 border border-slate-600 text-slate-200 rounded-lg font-bold text-lg hover:bg-slab-800 transition-colors"
      >
        📖 查看文档
      </a>
    </div>

    <!-- GitHub Stars (静态, 避免 JS 依赖) -->
    <div class="mt-8">
      <a
        href="https://github.com/232252/education-advisor"
        class="inline-flex items-center gap-2 text-slate-400 hover:text-rust text-sm"
      >
        <svg class="w-5 h-5" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        Star on GitHub
      </a>
    </div>
  </div>
</section>
