{
  "name": "education-advisor",
  "productName": "Education Advisor",
  "version": "0.2.0-rc.1",
  "description": "Education Advisor — Tauri 2.0 + Rust desktop app. 18 specialized AI agents, privacy-preserving PII engine, cross-platform LLM orchestration, all wrapped in a native-feeling Rust+WebView app.",
  "private": false,
  "type": "module",
  "author": {
    "name": "Education Advisor AI Contributors",
    "url": "https://github.com/232252/education-advisor"
  },
  "license": "MIT OR Apache-2.0",
  "homepage": "https://github.com/232252/education-advisor#readme",
  "bugs": {
    "url": "https://github.com/232252/education-advisor/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/232252/education-advisor.git",
    "directory": "."
  },
  "keywords": [
    "ai",
    "agent",
    "education",
    "tauri",
    "desktop",
    "multi-agent",
    "llm",
    "privacy",
    "rust"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev:renderer": "vite --config vite.config.renderer.ts",
    "build:renderer": "vite build --config vite.config.renderer.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check src/ --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist release src-tauri/target src-tauri/gen",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug",
    "cargo:check": "cargo check --manifest-path src-tauri/Cargo.toml --lib",
    "cargo:check:1.95": "cargo +1.95.0 check --manifest-path src-tauri/Cargo.toml --lib",
    "cargo:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "signer:gen": "node scripts/gen-signer.mjs"
  },
  "dependencies": {
    "typebox": "1.1.38",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@tanstack/react-table": "^8.20.0",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "rimraf": "^6.0.1",
    "shiki": "^4.2.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.4",
    "zustand": "^5.0.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-os": "^2",
    "@tauri-apps/plugin-log": "^2"
  }
}
